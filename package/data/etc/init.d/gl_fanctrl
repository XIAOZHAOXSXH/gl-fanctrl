#!/bin/sh /etc/rc.common

START=98
STOP=15
USE_PROCD=1

. /usr/share/fanctrl/fanctrl-common.sh

start_service() {
	load_config
	ensure_run_dir

	[ "$enabled" = "1" ] || {
		status_write "disabled"
		return 0
	}

	stop_official_fan

	procd_open_instance
	procd_set_param command /usr/sbin/gl-fanctrl-daemon
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	local cooling
	cooling="$(get_cooling_device || true)"
	[ -n "$cooling" ] && write_pwm_percent "$cooling" 0 >/dev/null 2>&1 || true
	rm -f "$PID_FILE" "$MANUAL_FILE" "$APPLY_FILE"
	status_write "stopped"
	load_config
	[ "$enabled" = "1" ] || start_official_fan
}

reload_service() {
	stop_service
	start_service
}

service_triggers() {
	procd_add_reload_trigger gl_fanctrl
}
